{
  "name": "pi-elixir",
  "version": "0.4.0",
  "description": "BEAM runtime tools for pi — connects to the running Elixir app for live introspection",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dannote/pi-elixir"
  },
  "files": [
    "src",
    "scripts",
    "skills",
    "README.md"
  ],
  "scripts": {
    "lint": "bun run lint:structure && oxlint -c .oxlintrc.json --type-aware --type-check src/",
    "lint:structure": "oxlint -c .oxlintrc.json src/ test/ vitest.config.ts",
    "fmt": "oxfmt --write .oxfmtrc.json .oxlintrc.json package.json tsconfig.json vitest.config.ts src/ test/",
    "fmt:check": "oxfmt --check .oxfmtrc.json .oxlintrc.json package.json tsconfig.json vitest.config.ts src/ test/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run test/integration/",
    "test:dupes": "jscpd src --min-lines 5 --min-tokens 50 --format typescript --threshold 0",
    "check": "bun run lint && bun run typecheck && bun run fmt:check && bun run test && bun run test:dupes"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "jscpd": "^4.0.5",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  }
}
